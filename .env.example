# ============================================================
# SonoffLAN-InfluxDB — Environment Variable Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# All REQUIRED vars must be set; OPTIONAL vars can be removed.
# ============================================================

# ---- Sonoff Devices (REQUIRED) ----
# JSON array of device objects. Each object requires:
#   device_id  — the 10-digit Sonoff device ID
#   uiid       — Sonoff device type ID (e.g. 190 for POWR3/POWCT, 32 for S31, 126 for DualR3)
#                Find yours in the eWeLink app device info or from the cloud API data.
#                This is NOT broadcast via mDNS and MUST be provided in the config.
#   devicekey  — 32-char AES key (omit for DIY/unencrypted devices)
#   device_name — optional human-readable label (defaults to device_id)
#   ip         — optional static IP; when set, mDNS is bypassed and the device is polled
#                via HTTP at SONOFF_POLL_INTERVAL cadence. Use on macOS or Docker where
#                mDNS multicast is unavailable.
#
# Example (single encrypted device):
# SONOFF_DEVICES=[{"device_id":"1000xxxxxx","uiid":190,"devicekey":"abcd1234abcd1234abcd1234abcd1234","device_name":"Kitchen Socket"}]
#
# Example (multiple devices, one DIY):
# SONOFF_DEVICES=[{"device_id":"1000aaaaaa","uiid":190,"devicekey":"key1...","device_name":"Living Room"},{"device_id":"1000bbbbbb","uiid":32,"device_name":"DIY Plug"}]
#
# Example (static IP device, no mDNS):
# SONOFF_DEVICES=[{"device_id":"1000xxxxxx","uiid":190,"devicekey":"abcd...","ip":"192.168.1.50","device_name":"Kitchen Socket"}]
#
# Example (mixed: static IP + mDNS device in same daemon):
# SONOFF_DEVICES=[{"device_id":"1000aaaaaa","uiid":190,"devicekey":"key1...","ip":"192.168.1.50"},{"device_id":"1000bbbbbb","uiid":32}]
SONOFF_DEVICES=[{"device_id":"YOUR_DEVICE_ID","uiid":190,"devicekey":"YOUR_32CHAR_KEY","device_name":"My Sonoff"}]

# ---- InfluxDB 3 Core (REQUIRED) ----
# Full URL to your InfluxDB 3 Core instance
INFLUX_HOST=http://192.168.1.100:8086

# InfluxDB auth token (create in InfluxDB UI → Load Data → API Tokens)
INFLUX_TOKEN=your-influxdb-token-here

# InfluxDB database / bucket name
INFLUX_DATABASE=sonoff

# ---- Logging (OPTIONAL) ----
# Control log verbosity. Valid values: DEBUG, INFO, WARNING, ERROR, CRITICAL (case-insensitive).
# Defaults to INFO if not set.
# Use DEBUG during initial device bring-up to see raw mDNS payloads.
# LOG_LEVEL=INFO

# ---- Polling (OPTIONAL) ----
# Poll interval in seconds for devices configured with a static ip field.
# Only relevant when any SONOFF_DEVICES entry has "ip" set.
# Must be a positive integer. Defaults to 10 seconds if not set.
# SONOFF_POLL_INTERVAL=10
